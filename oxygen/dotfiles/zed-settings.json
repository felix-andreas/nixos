{
  // changed via ui
  "auto_signature_help": true,
  // telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  // base
  "ui_font_size": 16,
  "buffer_font_size": 12,
  "buffer_line_height": "standard",
  "show_wrap_guides": true,
  "wrap_guides": [80, 88, 100, 120],
  "cursor_blink": false,
  "ui_font_family": "Inter Variable",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "search": {
    "center_on_match": true,
  },
  "soft_wrap": "editor_width",
  "icon_theme": "JetBrains New UI Icons (Light)",
  "theme": "GitHub Light",
  // "experimental.theme_overrides": {
  //   "border": "#d1d9e0ff",
  //   "border.variant": "#d1d9e0ff",
  //   "editor.active_line.background": "#f6f8faff",
  //   "editor.wrap_guide": "#e3e8ecff",
  //   "icon.border": "#d1d9e0ff",
  //   "pane.focused_border": "#d1d9e0ff",
  //   "panel.focused_border": "#d1d9e0ff",
  //   "scrollbar.thumb.background": "#dae0e6ff",
  // },
  // vim
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
  },
  // languages
  "languages": {
    "R": {
      "language_servers": ["roughly"],
    },
    "Python": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-c",
            "ruff check --exit-zero --fix --unsafe-fixes --stdin-filename {buffer_path} | ruff format --stdin-filename {buffer_path}",
          ],
        },
      },
    },
  },
  "lsp": {
    "roughly": {
      "binary": {
        "path": "/home/felix/Projects/roughly/target/debug/roughly",
        "arguments": ["server", "--stdio"],
      },
    },
  },
  // ai
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
      "enable_thinking": false,
    },
    "default_profile": "write",
    "tool_permissions": {
      "tools": {
        "save_file": {
          "default": "allow",
        },
        "terminal": {
          "default": "allow",
        },
      },
      "default": "allow",
    },
    "dock": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
    },
  },
  "edit_predictions": {
    "mode": "subtle",
  },
}
